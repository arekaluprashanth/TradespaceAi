{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Backend Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:server"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Run Production Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "prod"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Open Browser (Production)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3001",
      "webRoot": "${workspaceFolder}/client",
      "preLaunchTask": "Build Frontend",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Run Production + Browser",
      "type": "compound",
      "configurations": ["Run Production Server", "Open Browser (Production)"],
      "stopAll": true
    }
  ]
}
